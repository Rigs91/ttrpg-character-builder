# API host and port
HOST=0.0.0.0
PORT=8787

# Storage mode: memory is the default local-safe option.
# Set FORGE_STORAGE=prisma only if DATABASE_URL points at a local PostgreSQL instance.
FORGE_STORAGE=memory
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/forge_character

# Optional local AI assist
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Optional frontend override when running the React app directly
VITE_API_BASE_URL=http://localhost:8787
